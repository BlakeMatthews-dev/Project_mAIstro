# Conductor Phase 0 — Environment Variables
# Copy to .env and edit: cp .env.example .env

# ── CouchDB (for Obsidian LiveSync sync mode) ──
COUCHDB_USER=admin
COUCHDB_PASSWORD=conductor

# ── Langfuse SDK (used by gateway + orchestrator) ──
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-conductor
LANGFUSE_SECRET_KEY=sk-lf-conductor

# ── Langfuse v3 Docker internals (change all of these for production!) ──
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=CHANGE-ME-random-32-hex
LANGFUSE_SALT=CHANGE-ME-random-32-hex
ENCRYPTION_KEY=CHANGE-ME-random-64-hex-string
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse
REDIS_AUTH=conductorredis
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=conductorminio

# ── Gateway overrides (pydantic-settings reads CONDUCTOR_ prefix) ──
# CONDUCTOR_LLAMA_SERVER_URL=http://localhost:8080
# CONDUCTOR_TEMPLATE_SLOT_ID=0
# CONDUCTOR_WORKER_SLOT_IDS=[1,2,3,4]
# CONDUCTOR_KV_CACHE_DIR=./data/kv-cache
# CONDUCTOR_TIER2_CANDIDATES=3
# CONDUCTOR_TIER3_CANDIDATES=5
# CONDUCTOR_DEFAULT_MAX_TOKENS=4096
# CONDUCTOR_GENERATION_TIMEOUT_SECONDS=300
# CONDUCTOR_METRICS_LOG_PATH=./data/metrics/gateway.jsonl
